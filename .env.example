# Main Express Storybook API (class deployment on Render).
STORY_API_URL=https://storybook-api-f6bt.onrender.com

# Standalone Flask NPC service (personal Render deployment). The five NPC
# routes are proxied here; when unset they fall back to STORY_API_URL, which
# serves the identical contract.
# NPC_API_URL=https://your-npc-service.onrender.com

# Optional: enables self-serve sign-up on the login page. Talks straight to
# Supabase Auth from the browser (not through the class API, which only
# exposes login) — same project as STORY_API_URL, same "publishable"/anon key
# the Express server itself uses (SUPABASE_PUBLISHABLE_KEY in its own .env).
# Find these in the Supabase dashboard → Project Settings → API. Both are
# safe to expose to the browser (NEXT_PUBLIC_ vars are public by design).
# Without them, the login page shows sign-in only, unchanged.
# NEXT_PUBLIC_SUPABASE_URL=https://<your-project>.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-public-key>
